# Copy to `.env` and fill in values. Never commit `.env`.

# --- Postgres (local or Neon) ---
# Local: same URL twice if you are not behind PgBouncer.
# Neon: use the dashboard "Connection details" — you need TWO strings for the same database:
#   - Pooled (PgBouncer / "pooler" host) → DATABASE_URL
#   - Direct (non-pooler host) → DATABASE_URL_UNPOOLED
# Example shape (replace USER, PASSWORD, HOSTS, DB name with yours):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/DB?sslmode=require"

DATABASE_URL="postgresql://postgres:password@localhost:5432/disco"
# Same as DATABASE_URL for local Postgres; on Neon/Vercel use the non-pooler "direct" URL for Prisma migrate.
DATABASE_URL_UNPOOLED="postgresql://postgres:password@localhost:5432/disco"

# Base URL of the Next app (render worker loads pages from here).
# WEB_URL="http://localhost:3000"

# Authentication
# openssl rand -base64 32
# NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Path to Chrome for video rendering; "auto" downloads a compatible build when possible.
CHROME_PATH="auto"

# Optional: Vercel "Protection Bypass for Automation" secret. When the render worker points
# `WEB_URL` at a Vercel deployment that has Deployment Protection on, Puppeteer appends this
# as a query param so requests are accepted. Leave blank otherwise.
# VERCEL_AUTOMATION_BYPASS_SECRET=""

# Required when the Vercel-hosted app must serve videos rendered by a remote worker (#18).
# Create a Vercel Blob store (Vercel → Storage → Blob) to get this token. Leave blank when
# running `yarn dev` + `yarn work` on the same machine — the API routes then fall back to
# reading the worker's local temp/ directory.
# BLOB_READ_WRITE_TOKEN=""
